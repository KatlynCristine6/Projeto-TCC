<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Usuários 💖</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>

        body{
            background: linear-gradient(135deg, #ffe4ec, #f8d7ff);
            min-height: 100vh;
            font-family: 'Segoe UI', sans-serif;
            padding: 40px 0;
        }

        .container-custom{
            background: rgba(255,255,255,0.92);
            border-radius: 25px;
            padding: 35px;
            backdrop-filter: blur(10px);
        }

        .title{
            color: #d63384;
            font-weight: bold;
        }

        .subtitle{
            color: #c2185b;
            font-size: 14px;
        }

        .btn-pink{
            background: linear-gradient(90deg, #ff69b4, #ff85c1);
            border: none;
            border-radius: 14px;
            color: white;
            font-weight: bold;
            padding: 10px 18px;
            transition: 0.3s;
        }

        .btn-pink:hover{
            transform: scale(1.03);
            background: linear-gradient(90deg, #ff4fa3, #ff70b8);
            color: white;
        }

        .table{
            overflow: hidden;
            border-radius: 18px;
        }

        .table thead{
            background: linear-gradient(90deg, #ff69b4, #ff85c1);
            color: white;
        }

        .table th{
            border: none;
            padding: 16px;
        }

        .table td{
            padding: 16px;
            vertical-align: middle;
        }

        .table tbody tr{
            transition: 0.2s;
        }

        .table tbody tr:hover{
            background-color: #fff0f7;
        }

        .badge-custom{
            background-color: #ff85c1;
            color: white;
            padding: 8px 12px;
            border-radius: 12px;
            font-size: 13px;
        }

        .btn-edit{
            border-radius: 10px;
            border: 2px solid #ff85c1;
            color: #d63384;
            font-weight: 600;
            transition: 0.2s;
        }

        .btn-edit:hover{
            background-color: #ff85c1;
            color: white;
        }

        .btn-delete{
            border-radius: 10px;
            border: 2px solid #ff4d6d;
            color: #ff4d6d;
            font-weight: 600;
            transition: 0.2s;
        }

        .btn-delete:hover{
            background-color: #ff4d6d;
            color: white;
        }

        code{
            background-color: #ffe4ec;
            padding: 5px 10px;
            border-radius: 8px;
            color: #d63384;
        }

        .emoji{
            font-size: 28px;
        }

    </style>

</head>

<body>

    <div class="container">

        <div class="container-custom shadow-lg">

            <div class="d-flex justify-content-between align-items-center mb-4">

                <div>

                    <div class="emoji">💖✨</div>

                    <h1 class="title">
                        Gerenciamento de Usuários
                    </h1>

                    <div class="subtitle">
                        Sua lista fashion de usuários 💅
                    </div>

                </div>

                <a href="/user/create" class="btn btn-pink">
                    + Novo Usuário
                </a>

            </div>

            <div class="table-responsive">

                <table class="table align-middle">

                    <thead>

                        <tr>
                            <th>ID</th>
                            <th>Username</th>
                            <th>Email</th>
                            <th>Senha</th>
                            <th class="text-center">Ações</th>
                        </tr>

                    </thead>

                    <tbody>

                        <% for(usuario of usuarios) { %>

                            <tr>

                                <td>
                                    <span class="badge-custom">
                                        #<%= usuario.id %>
                                    </span>
                                </td>

                                <td>
                                    <strong>
                                        <%= usuario.username %>
                                    </strong>
                                </td>

                                <td>
                                    <%= usuario.email %>
                                </td>

                                <td>
                                    <code>********</code>
                                </td>

                                <td class="text-center">

                                    <div class="btn-group">

                                        <a
                                            href="/user/edit/<%= usuario.id %>"
                                            class="btn btn-edit btn-sm"
                                        >
                                            ✏️ Editar
                                        </a>

                                        <button
                                            onclick="apagarUsuario('<%= usuario.id %>')"
                                            class="btn btn-delete btn-sm"
                                        >
                                            🗑️ Apagar
                                        </button>

                                    </div>

                                </td>

                            </tr>

                        <% } %>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</body>

<script>

    async function apagarUsuario(id){

        if(!confirm("💖 Tem certeza que deseja excluir este usuário?")){
            return;
        }

        const url = "/user/delete/" + id;

        try{

            const response = await fetch(url, {

                method: 'DELETE'

            });

            const data = await response.json();

            if(!response.ok){

                alert("❌ Ocorreu um erro na requisição");
                console.log("Erro:", data);

            }else{

                console.log("Excluído com sucesso:", data);

                location.reload();

            }

        }catch(error){

            alert("⚠️ Erro de conexão.");

        }
    }

</script>

</html>