<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Editar Usuário ✨</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>

        body{
            background: linear-gradient(135deg, #ffe4ec, #f8d7ff);
            min-height: 100vh;
            display: flex;
            align-items: center;
            font-family: 'Segoe UI', sans-serif;
        }

        .card{
            border: none;
            border-radius: 25px;
            background: rgba(255,255,255,0.92);
            backdrop-filter: blur(10px);
            overflow: hidden;
        }

        .card-header{
            background: linear-gradient(90deg, #ff69b4, #ff85c1);
            color: white;
            font-size: 24px;
            font-weight: bold;
            border: none;
            padding: 20px;
        }

        .subtitle{
            color: #c2185b;
            font-size: 14px;
            margin-top: -5px;
        }

        .form-label{
            color: #c2185b;
            font-weight: 600;
        }

        .form-control{
            border-radius: 14px;
            border: 2px solid #f3c4d7;
            padding: 12px;
        }

        .form-control:focus{
            border-color: #ff69b4;
            box-shadow: 0 0 10px rgba(255,105,180,0.4);
        }

        .btn-pink{
            background: linear-gradient(90deg, #ff69b4, #ff85c1);
            border: none;
            border-radius: 14px;
            padding: 12px;
            color: white;
            font-size: 18px;
            font-weight: bold;
            transition: 0.3s;
        }

        .btn-pink:hover{
            transform: scale(1.02);
            background: linear-gradient(90deg, #ff4fa3, #ff70b8);
        }

        .link-voltar{
            color: #c2185b;
            font-weight: 500;
        }

        .link-voltar:hover{
            color: #ff1493;
        }

        .emoji{
            font-size: 32px;
        }

    </style>
</head>

<body>

    <div class="container">

        <div class="row justify-content-center">

            <div class="col-md-5">

                <div class="card shadow-lg">

                    <div class="card-header text-center">

                        <div class="emoji">💖✨</div>

                        Edição de Usuário

                        <div class="subtitle">
                            Atualize suas informações com estilo 💅
                        </div>

                    </div>

                    <div class="card-body p-4">

                        <form>

                            <input 
                                value="<%= usuario.id %>"
                                type="hidden"
                                id="usuarioId"
                            >

                            <div class="mb-3">

                                <label for="username" class="form-label">
                                    Username
                                </label>

                                <input
                                    value="<%= usuario.username %>"
                                    type="text"
                                    id="username"
                                    class="form-control"
                                >

                            </div>

                            <div class="mb-3">

                                <label for="email" class="form-label">
                                    E-mail
                                </label>

                                <input
                                    value="<%= usuario.email %>"
                                    type="email"
                                    id="email"
                                    class="form-control"
                                >

                            </div>

                            <div class="mb-4">

                                <label for="senha" class="form-label">
                                    Nova Senha
                                </label>

                                <input
                                    type="password"
                                    id="senha"
                                    class="form-control"
                                    placeholder="••••••••"
                                >

                            </div>

                            <div class="d-grid gap-2">

                                <button
                                    id="btnSalvarEdicao"
                                    class="btn btn-pink btn-lg"
                                    type="submit"
                                >
                                    💖 Salvar Alterações
                                </button>

                                <a
                                    href="/user/list"
                                    class="btn text-decoration-none text-center link-voltar"
                                >
                                    ← Cancelar e Voltar
                                </a>

                            </div>

                        </form>

                    </div>

                </div>

                <div id="statusMessage" class="mt-3"></div>

            </div>

        </div>

    </div>

</body>

<script>

    const btnSalvarEdicao = document.getElementById("btnSalvarEdicao");
    const statusMessage = document.getElementById("statusMessage");

    btnSalvarEdicao.addEventListener("click", salvarUsuario);

    async function salvarUsuario(e){

        e.preventDefault();

        const id = document.getElementById("usuarioId");
        const username = document.getElementById("username");
        const email = document.getElementById("email");
        const senha = document.getElementById("senha");

        const url = "/user/edit";

        try{

            const response = await fetch(url, {

                method: 'PUT',

                headers:{
                    'Content-Type': 'application/json'
                },

                body: JSON.stringify({

                    id: id.value,
                    username: username.value,
                    email: email.value,
                    senha: senha.value

                })

            });

            const data = await response.json();

            if(!response.ok){

                statusMessage.innerHTML = `
                    <div class="alert alert-danger rounded-4">
                        ❌ Erro ao atualizar dados!
                    </div>
                `;

            }else{

                statusMessage.innerHTML = `
                    <div class="alert alert-success rounded-4">
                        💖 Dados atualizados com sucesso!
                    </div>
                `;

                setTimeout(() => {

                    window.location.href = "/user/list";

                }, 1500);

            }

            console.log(data);

        }catch(error){

            statusMessage.innerHTML = `
                <div class="alert alert-danger rounded-4">
                    ⚠️ Erro de conexão com servidor.
                </div>
            `;
        }
    }

</script>

</html>